PORT=3000
# Local PostgreSQL example:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/smartsplit?schema=public"
#
# Supabase session pooler example (recommended for this app on IPv4 networks):
# DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@[REGION].pooler.supabase.com:5432/postgres?schema=public"
JWT_SECRET="legacy-jwt-secret-if-you-still-use-custom-auth"
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
CORS_ORIGIN="http://localhost:5173,https://smart-split-expanse.vercel.app"
# Optional template: use {base} where the source currency should go.
# EXCHANGE_RATE_API_URL="https://open.er-api.com/v6/latest/{base}"
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"
CLOUDINARY_FOLDER="smartsplit/receipts"
OPENAI_API_KEY="your-openai-api-key"
OPENAI_RECEIPT_MODEL="gpt-4.1-mini"
OPENAI_CHAT_MODEL="gpt-4.1-mini"
