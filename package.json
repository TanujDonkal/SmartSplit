{
  "name": "smartsplit",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "mobile"
  ],
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "4.16.0",
    "react-native-gesture-handler": "2.28.0"
  },
  "scripts": {
    "dev:web": "npm --workspace client run dev",
    "dev:server": "npm --workspace server run dev",
    "dev:mobile": "npm --workspace mobile run start",
    "build:web": "npm --workspace client run build",
    "build:server": "npm --workspace server run build",
    "typecheck:mobile": "npm --workspace mobile run typecheck"
  }
}
