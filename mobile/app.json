{
  "expo": {
    "name": "SmartSplit",
    "slug": "smartsplit-mobile",
    "scheme": "smartsplit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#fffdfa"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.smartsplit.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#fffdfa"
      },
      "package": "com.smartsplit.mobile",
      "versionCode": 1
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "SmartSplit needs access to your photo library so you can upload receipt images.",
          "mediaLibraryPermission": "SmartSplit needs access to your media library so you can upload receipt images."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
